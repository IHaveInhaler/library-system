# Copy this to .env and fill in values before running docker compose

JWT_ACCESS_SECRET=change-me-to-a-long-random-string-32chars-min
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string

# Set to "development" for dev features (seed defaults, use existing DB, dev mode)
# Set to "production" for production use (setup runs once only)
NODE_ENV=production

# Optional overrides
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost

# SMTP — set these to override the DB settings (env takes precedence and locks the field in the UI)
# SMTP_ENABLED=false
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# APP_BASE_URL=
